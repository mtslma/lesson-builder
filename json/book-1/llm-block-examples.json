      "id": "p2-listen1",
      "type": "listening",
      "title": "Listen and Answer",
      "instruction": "In this exercise, you are Sofia. Answer the questions.",
      "audioUrl": "audio/example.mp3",
      "contextImageUrl": "https://images.unsplash.com/photo-1690444963408-9573a17a8058?q=80&w=627&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
      "script": [
        {
          "id": "b4e2e2c3-9b12-4db4-9a36-6c445e98ffad",
          "speaker": "Lucas",
          "text": "Hi Sofia! Do you study English?",
          "highlights": [
            {
              "id": "ace76cb1-35ec-49f9-baa6-4b6e173397d8",
              "text": "Do",
              "color": "#bfdbfe"
            },
            {
              "id": "7642da58-5eb3-4e50-9dc2-e5b13ffeaa48",
              "text": "you",
              "color": "#d9f99d"
            },
            {
              "id": "6e775391-4e2c-482f-b819-51dc67e2e8c4",
              "text": "study English",
              "color": "#d6b2eea2"
            }
          ]
        },
        {
          "id": "ba7fd5a4-d6fc-47f9-bacd-f6c033e2765b",
          "speaker": "Sofia",
          "text": "Hello! Yes, I do. I study at night.",
          "highlights": [
            {
              "id": "8f4dc50e-8e48-4c08-b915-362bd181b771",
              "text": "I",
              "color": "#d9f99d"
            },
            {
              "id": "41aba38c-3249-4c76-9bde-7dd01cf35c19",
              "text": "do",
              "color": "#bfdbfe"
            },
            {
              "id": "fa9ea78e-7d5b-417b-bf66-2a874dbc3104",
              "text": "study at night",
              "color": "#d6b2eea2"
            }
          ]
        },
        {
          "id": "37652067-f3c3-464d-9ee1-5a73a77cf95e",
          "speaker": "Lucas",
          "text": "Do you work?",
          "highlights": [
            {
              "id": "bd788086-4a13-426c-a05a-297137039ce1",
              "text": "you",
              "color": "#d9f99d"
            },
            {
              "id": "beeae363-4f60-41a7-a740-4d5face64757",
              "text": "Do",
              "color": "#bfdbfe"
            },
            {
              "id": "41db9d91-1bf8-46d1-8f91-dc1bf99a4d6f",
              "text": "work",
              "color": "#d6b2eea2"
            }
          ]
        },
        {
          "id": "cc8c539d-c26f-453f-9ca0-b39e438f3b28",
          "speaker": "Sofia",
          "text": "No, I don't. I don't have time to.",
          "highlights": [
            {
