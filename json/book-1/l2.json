        {
          "id": "p1-conv1-m1",
          "speaker": "Cashier",
          "text": "Hi! Welcome to Burger Town.",
          "highlights": [
            {
              "id": "p1-conv1-h1",
              "text": "Welcome",
              "color": "#d9f99d"
            }
          ]
        },
        {
          "id": "p1-conv1-m2",
          "speaker": "Maya",
          "text": "Hi! Can I see the menu, please?",
          "highlights": [
            {
              "id": "p1-conv1-h2",
              "text": "Can I see the menu, please",
              "color": "#bfdbfe"
            }
          ]
        },
        {
          "id": "p1-conv1-m3",
          "speaker": "Cashier",
          "text": "Sure. Do you want a burger or a sandwich?",
          "highlights": [
            {
              "id": "p1-conv1-h3",
              "text": "Do you want",
              "color": "#d6b2eea2"
            }
          ]
        },
        {
          "id": "p1-conv1-m4",
          "speaker": "Maya",
          "text": "I want a burger and fries, please.",
          "highlights": [
            {
              "id": "p1-conv1-h4",
              "text": "I want",
              "color": "#fde68a"
            }
          ]
        },
        {
          "id": "p1-conv1-m5",
          "speaker": "Cashier",
          "text": "Do you want a drink?",
          "highlights": [
            {
              "id": "p1-conv1-h5",
              "text": "Do you want",
              "color": "#d6b2eea2"
            }
          ]
        },
        {
          "id": "p1-conv1-m6",
          "speaker": "Maya",
          "text": "Yes, I do. I want orange juice.",
          "highlights": [
            {
              "id": "p1-conv1-h6",
              "text": "Yes, I do",
              "color": "#d9f99d"
            }
          ]
        },
        {
          "id": "p1-conv1-m7",
          "speaker": "Cashier",
          "text": "Great. That's twelve dollars.",
          "highlights": [
            {
              "id": "p1-conv1-h7",
              "text": "twelve dollars",
              "color": "#bfdbfe"
            }
          ]
        },
        {
          "id": "p1-conv1-m8",
          "speaker": "Maya",
          "text": "Here you go.",
          "highlights": []
